# PostgreSQL
POSTGRES_DB=softtime_db
POSTGRES_USER=softtime
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# Redis (не менять если используете docker-compose)
REDIS_URL=redis://redis:6379

# JWT — сгенерируйте: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_random_64_hex_string
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Firebase Cloud Messaging — Firebase Console → Project Settings → Cloud Messaging
FCM_SERVER_KEY=CHANGE_ME_your_fcm_server_key

# App
APP_NAME=SoftTime
DEBUG=false
# true — только на первом запуске, потом false (используйте Alembic)
AUTO_CREATE_TABLES=true

# Default Super Admin (создаётся при первом запуске через bootstrap.py)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@softjol.com
DEFAULT_ADMIN_PASSWORD=CHANGE_ME_strong_password
DEFAULT_ADMIN_PHONE=+99600000000
