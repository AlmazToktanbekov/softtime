# PostgreSQL
POSTGRES_DB=softtime_db
POSTGRES_USER=softtime
POSTGRES_PASSWORD=your_password_here

# Redis
REDIS_URL=redis://redis:6379

# JWT — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-random-32-char-secret-key-here
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# App
APP_NAME=SoftTime
DEBUG=false
AUTO_CREATE_TABLES=false

# Default Super Admin (создаётся при первом запуске)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@softjol.com
DEFAULT_ADMIN_PASSWORD=changeme_in_production
DEFAULT_ADMIN_PHONE=+99600000000
