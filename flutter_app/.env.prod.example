# SoftTime Production Configuration
# Copy to .env.prod and fill in your values

# ─── DATABASE ──────────────────────────────────────────────────────────────
DB_NAME=softtime
DB_USER=softtime
DB_PASSWORD=your_secure_password_here_change_me
DB_PORT=5432

# ─── REDIS ─────────────────────────────────────────────────────────────────
REDIS_PASSWORD=your_secure_redis_password_change_me
REDIS_PORT=6379

# ─── JWT & SECURITY ────────────────────────────────────────────────────────
SECRET_KEY=your_very_long_secret_key_change_this_in_production_use_strong_random_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── APPLICATION ──────────────────────────────────────────────────────────
APP_TITLE=SoftTime
APP_VERSION=2.0
ENVIRONMENT=production
LOG_LEVEL=info

# ─── ADMIN CREDENTIALS ─────────────────────────────────────────────────────
# Default admin user created on first run
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=your_secure_admin_password_here
ADMIN_USERNAME=admin

# ─── FIREBASE (FCM) ────────────────────────────────────────────────────────
# Paste your firebase-adminsdk.json content or mount file
FIREBASE_CREDENTIALS_PATH=/app/firebase-adminsdk.json

# ─── CORS & ORIGINS ───────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com,https://app.yourdomain.com

# ─── TIMEZONE ──────────────────────────────────────────────────────────────
TZ=Asia/Bishkek

# ─── PORTS ────────────────────────────────────────────────────────────────
BACKEND_PORT=8000
ADMIN_WEB_PORT=3000

# ─── NGINX/SSL (Optional) ─────────────────────────────────────────────────
# If using reverse proxy, configure SSL certificates
# SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
# SSL_KEY_PATH=/etc/nginx/ssl/key.pem
